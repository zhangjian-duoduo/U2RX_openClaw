menu "RT-Thread Kernel"
config RT_NAME_MAX
    int "The maximal size of kernel object name"
    range 2 32
    default 16
    help
        Each kernel object, such as thread, timer, semaphore etc, has a name,
        the RT_NAME_MAX is the maximal size of this object name.

config RT_USING_SMP
    bool "Enable SMP(Symmetric multiprocessing)"
    default n
    help
        This option should be selected by machines which have an SMP-
        capable CPU.
        The only effect of this option is to make the SMP-related
        options available to the user for configuration.

config RT_CPUS_NR
    int "Number of CPUs"
    default 2
    depends on RT_USING_SMP
    help
        Number of CPUs in the system

config RT_ALIGN_SIZE
    int "Alignment size for CPU architecture data access"
    default 4
    help
        Alignment size for CPU architecture data access

    choice
        prompt "The maximal level value of priority of thread"
        default RT_THREAD_PRIORITY_256

        config RT_THREAD_PRIORITY_8
            bool "8"

        config RT_THREAD_PRIORITY_32
            bool "32"

        config RT_THREAD_PRIORITY_256
            bool "256"
    endchoice

config RT_THREAD_PRIORITY_MAX
    int
    default 8   if RT_THREAD_PRIORITY_8
    default 32  if RT_THREAD_PRIORITY_32
    default 256 if RT_THREAD_PRIORITY_256

config RT_TICK_PER_SECOND
    int "Tick frequency, Hz"
    range 10 1000
    default 100
    help
        System's tick frequency, Hz.

config MAX_HANDLERS
    int "Interrupt Descriptor Number"
    range 256 2048
    help
        Used interrupt descriptor number

config RT_USING_VFP
    bool "vfp"
    default y

config RT_USING_HOOK
    bool "Enable system hook"
    default y
    select RT_USING_IDLE_HOOK
    help
        Enable the hook function when system running, such as idle thread hook,
        thread context switch etc.

config RT_USING_IDLE_HOOK
    bool "Enable IDLE Task hook"
    default y if RT_USING_HOOK

    if RT_USING_IDLE_HOOK
    config RT_IDEL_HOOK_LIST_SIZE
        int "The max size of idel hook list"
        default 4
        range 1 16
        help
            The system has a hook list. This is the hook list size.
    endif

config IDLE_THREAD_STACK_SIZE
    int "The stack size of idle thread"
    default 1024

config RT_USING_CPU_IDLE
    bool "Use cpu idle function when idle"
    default n
    help
        Use cpu idle function when idle
        now only armv6 supportted by WFI

config RT_USING_TIMER_SOFT
    bool "Enable software timer with a timer thread"
    default y
    help
        the timeout function context of soft-timer is under a high priority timer
        thread.

if RT_USING_TIMER_SOFT
config RT_TIMER_THREAD_PRIO
    int "The priority level value of timer thread"
    default 8

config RT_TIMER_THREAD_STACK_SIZE
    int "The stack size of timer thread"
    default 2048

endif

config USER_INIT_THREAD_STACK_SIZE
    int "The stack size of user main thread"
    default 32768

menuconfig RT_DEBUG
    bool "Enable debugging features"
    default y

if RT_DEBUG

config RT_DEBUG_COLOR
    bool "Enable color debugging log"
    default y


menuconfig RT_RUNLOG
    bool "Runlog debugging (Fullhan)"
    default n
    help
      If you say Y here, the /proc/runlog file will be provided
      that can help debug the scheduler/irq/sirq etc.

if RT_RUNLOG
config RT_RUNLOG_SIZE_KB
    int "Runlog size in KB"
    default 64

config RT_RUNLOG_USE_CUSTOM_MEM
    bool "Use custom memory"
    help
      Configure RT_RUNLOG_CUSTOM_MEM_ADDR used by runlog

if RT_RUNLOG_USE_CUSTOM_MEM
config RT_RUNLOG_CUSTOM_MEM_ADDR
    hex "Custom memory address"
endif

config RT_RUNLOG_COHERENT_MEM
    bool "Use coherent mem (noncached)"
    default n

config RT_RUNLOG_MEM_PERCPU
    bool "Separate memory for each cpu"
    help
      If you say Y here, total runlog size is RT_RUNLOG_SIZE_KB * NR_CPUS
    default n

config RT_RUNLOG_TRACE_SCHED
    bool "Sched trace enable"
    default y

if RT_RUNLOG_TRACE_SCHED
config SCHED_RUNTIME_WARN_US
    int "Sched warn runtime (us) (0:disable)"
    default 0
    help
      if a task runtime > SCHED_RUNTIME_WARN_US, print task info to
      console, set a zero value to disable this feature, also can be set by
      `runlog warn xxx`
endif

config RT_RUNLOG_TRACE_IRQ
    bool "IRQ trace enable"
    default y

config RT_RUNLOG_TRACE_WHEN_STARTUP
    bool "Enable runlog trace when startup"
    default y
    help
      enable when startup, if choose n, you can also run
      'runlog 0/1' to start/stop runlog
endif

config RT_USING_BACKTRACE
    bool "Enable backtrace"
    default n
    help
        Enable backtrace.

if RT_USING_SLAB
    config RT_USING_MM_TRACE
    bool "Enable memory management trace function"
endif

config RT_USING_OVERFLOW_CHECK
    bool "Using stack overflow checking"
    default y
    help
        Enable thread stack overflow checking. The stack overflow is checking when
        each thread switch.

