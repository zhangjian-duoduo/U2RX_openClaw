    bool "pwm"
    default y

config RT_USING_RTC
    bool "rtc"
    default y

    if RT_USING_RTC

    config RTC_SUPPORT_CLK_SRC_SWITCH
    bool
    default y
    depends on CONFIG_ARCH_FH8852V301_FH8662V100

    if RTC_SUPPORT_CLK_SRC_SWITCH
        choice
            prompt "select RTC clock source"
            default RTC_USE_OSC_CLK
            help
                depends on the hardware, select 'osc clk' if have oscillator,
                otherwise select 'clk on chip' (just ensure tsensor works,
                RTC cannot be used for timekeeping)
            config RTC_USE_OSC_CLK
                bool 'osc clk (32.768KHz)'
                help
                    if have oscillator in hardware, select this
            config RTC_USE_ONCHIP_CLK
                bool 'onchip clk'
                help
                    if select this, just ensure tsensor works, rtc-dev will not created
        endchoice
    endif
    config FH_USE_TSENSOR
        bool "USE TSENSOR"
        default y
    config FH_USE_TSENSOR_OFFSET
        bool "USE ENHANCEMENT TSENSOR"
        depends on FH_USE_TSENSOR
        default n
    config RT_USING_ALARM
        bool "Using rtc alarm func"
        default n
    config RTC_SYNC_USING_NTP
        bool "Using NTP auto sync RTC time"
        depends on PKG_NETUTILS_NTP
        default n

        if RTC_SYNC_USING_NTP
        config RTC_NTP_FIRST_SYNC_DELAY
            int "NTP first sync delay time(second) for network connect"
            default 30
        config RTC_NTP_SYNC_PERIOD
            int "NTP auto sync period(second)"
            default 3600
       endif
    endif

config FH_USING_SADC
    bool "sadc"
    default n

