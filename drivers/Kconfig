	bool "FH DesignWare AHB DMA support"
    depends on CONFIG_CHIP_FH8626V100
    default y

config FH_USING_AXI_DMA
    bool "dma"
    depends on !CONFIG_CHIP_FH8626V100 && !CONFIG_CHIP_MC632X && !CONFIG_ARCH_FH8852V301_FH8662V100 && !CONFIG_ARCH_FH8626V300
    default n

config FH_USING_MOL_DMA
	bool "dma"
	depends on CONFIG_CHIP_MC632X || CONFIG_ARCH_FH8852V301_FH8662V100 || CONFIG_ARCH_FH8626V300
	default y

config FH_USING_DMA_MEM
    bool "using dma memory"
    depends on FH_USING_DMA || FH_USING_AXI_DMA || FH_USING_MOL_DMA
    default y

config FH_USING_FLASH
    bool "flash"
    default y

    if FH_USING_FLASH
        config RT_MAX_FAL_PART_NUM
            int "max flash partition supported"
            default 10

        config RT_USING_SFUD
            bool "sfud"
            default y
            if RT_USING_SFUD
                config RT_SFUD_USING_QSPI
                    bool 
                    default n

                config CTL_DUAL_WIRE_SUPPORT
                    bool "flash using 2 wire read"
                    select RT_SFUD_USING_QSPI
                    default n

                config CTL_QUAD_WIRE_SUPPORT
                    bool "flash using 4 wire read"
                    select CTL_DUAL_WIRE_SUPPORT
                    select RT_SFUD_USING_QSPI
                    default n
            endif

        config RT_USING_FAL_SFUD_ADAPT
            bool "nor"
            select RT_USING_MTD_NOR

        config FH_USING_NAND_FLASH
            bool "nand"
            select RT_USING_MTD_NAND

        config SFUD_USING_SFDP
            bool
            default y

        config SFUD_USING_FLASH_INFO_TABLE
            bool
            default y

        config RT_CAPACITYID_DISCRIMINATE_FLASH
            bool
            default y
    endif

config FH_USING_GMAC
    bool "gmac"

if !FH_USING_GMAC
    config FH_USING_QOS_GMAC
    bool "qos gmac"
endif

config RT_USING_GPIO
    bool "gpio"
    default y

	if RT_USING_GPIO
	choice
		prompt "GPIO Driver"
		default RT_USING_DW_GPIO
		config RT_USING_DW_GPIO
			bool "Fullhan GPIO Driver"

		config RT_USING_MOL_GPIO
			bool "MolChip GPIO Driver"
	endchoice
	endif
config RT_USING_I2C
    bool "i2c"
    default y

