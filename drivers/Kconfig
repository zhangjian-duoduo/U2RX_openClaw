config SDKROOT
    string
    option env="SDKROOT"

menu "Drivers"

source "$SDKROOT/drivers/usb/Kconfig"
source "$SDKROOT/drivers/wifi/Kconfig"

menu "Choose uart device"
config FH_USING_UART0
    bool "Using uart0"
    default y

config FH_USING_UART1
    bool "Using uart1"
    default n

config FH_USING_UART2
    bool "Using uart2"
    default n
endmenu

config FH_USING_UART_DMA
    bool "Use Uart DMA"
    default n

config FH_USING_AES
    bool "aes"
    default y

if !FH_USING_AES
config FH_USING_CESA
    bool "cesa"
    default y

config FH_USING_EFUSE
    bool "efuse"
    default y
endif

choice
    prompt "different efuse version"
    depends on FH_USING_EFUSE
    default FH_EFUSE_V1

config FH_EFUSE_V1
    bool "fullhan byte access version"
    depends on FH_USING_EFUSE

config FH_EFUSE_V2
    bool "molchip block access version"
    depends on FH_USING_EFUSE
	
endchoice

config FH_USING_ACW
    bool "audio"
    default y

